# Bin_Parser Qt Project .gitignore

# Qt / qmake generated files
*.pro.user
.qmake.stash
ui_*.h
moc_*.cpp
moc_predefs.h

# Build directories (Debug / Release)
debug/
release/

# Object files
*.o
*.obj

# Makefiles (generated by qmake)
Makefile
Makefile.Debug
Makefile.Release

# Executables
*.exe

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db